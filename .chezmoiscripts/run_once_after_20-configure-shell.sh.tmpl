#!/bin/bash
set -eux

git() { command git -c merge.conflictstyle=diff3 "$@"; }

if [ "$SHELL" != "$(command -v zsh)" ]; then
  if [ -n "${CI:-}" ] || [ -n "${DEVCONTAINER:-}" ] || [ "$(id -u)" -eq 0 ]; then
    echo "Skipping chsh in container/CI/root environment"
  else
    chsh -s "$(command -v zsh)"
  fi
fi

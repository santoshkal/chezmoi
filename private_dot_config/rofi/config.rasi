configuration {
    modi: [ drun, run, window, filebrowser, ssh ];
    filebrowser {
        directories-first: true;
        sorting-method:    "name";
    }
    show-icons: true;
    font: "Hack Nerd Font Propo Italic 12";
    show-icons: true;
    display-ssh:    "󰣀 ssh:";

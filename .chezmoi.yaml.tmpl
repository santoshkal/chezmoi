
encryption: age
age:
  identity: ~/.config/chezmoi/key.txt
  recipient: age1u40akqxqkf3wpqfa9tfvz8x52axrl77gyszfarcyh4v2gc83l9zq8x4rnv

{{ $name := promptStringOnce . "name" "Your name for gitconfig: " }}
{{ $email := promptStringOnce . "email" "Your email address for gitconfig: " }}

{{- $is_arch := false }}
{{- $is_ubuntu := false }}
{{- $is_fedora := false }}
{{- $chassisType := "desktop" }}

{{- if eq .chezmoi.os "linux" }}
  {{- if hasKey .chezmoi.osRelease "id" }}
    {{- $is_fedora = eq .chezmoi.osRelease.id "fedora" }}
    {{- $is_arch = eq .chezmoi.osRelease.id "arch" }}
    {{- $is_ubuntu = eq .chezmoi.osRelease.id "ubuntu" }}
  {{- end }}

  {{- $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}
{{- end }}

sourceDir: "{{ .chezmoi.workingTree }}"

data:
  name: {{ $name }}
  email: {{ $email }}
  chassisType: {{ $chassisType }}
  is_arch: {{ $is_arch }}
  is_ubuntu: {{ $is_ubuntu }}
  is_fedora: {{ $is_fedora }}
